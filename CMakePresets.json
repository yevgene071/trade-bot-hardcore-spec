{
  "version": 6,
  "cmakeMinimumRequired": {"major": 3, "minor": 22, "patch": 0},
  "configurePresets": [
    {
      "name": "release",
      "displayName": "Release (AVX2, LTO, -O3 -march=native)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/build/release/conan_toolchain.cmake",
        "CMAKE_BUILD_TYPE": "Release",
        "ENABLE_AVX2": "ON",
        "ENABLE_SANITIZERS": "OFF",
        "BUILD_TESTS": "OFF",
        "BUILD_BENCHMARKS": "OFF"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug (AVX2, ASan+UBSan, -O0)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/build/debug/conan_toolchain.cmake",
        "CMAKE_BUILD_TYPE": "Debug",
        "ENABLE_AVX2": "ON",
        "ENABLE_SANITIZERS": "ON",
        "BUILD_TESTS": "ON",
        "BUILD_BENCHMARKS": "OFF"
      }
    }
  ],
  "buildPresets": [
    {"name": "release", "configurePreset": "release"},
    {"name": "debug",   "configurePreset": "debug"}
  ],
  "testPresets": [
    {
      "name": "release",
      "configurePreset": "release",
      "output": {"outputOnFailure": true},
      "execution": {"stopOnFailure": false}
    },
    {
      "name": "debug",
      "configurePreset": "debug",
      "output": {"outputOnFailure": true},
      "execution": {"stopOnFailure": false}
    }
  ]
}
